# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=bre_b_pse_db
DB_SSLMODE=disable

# ePayco
EPAYCO_CLIENT_ID=your_epayco_client_id
EPAYCO_CLIENT_SECRET=your_epayco_client_secret
EPAYCO_API_KEY=your_epayco_api_key
EPAYCO_PRIVATE_KEY=your_epayco_private_key

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRATION=86400

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@recaudos.com

# App
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Webhook
WEBHOOK_SECRET=your_webhook_secret
